---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const base = import.meta.env.BASE_URL;
---

<Layout title={project.data.title} description={project.data.description}>
  <Nav />

  <div class="max-w-[660px] mx-auto px-8 max-sm:px-5 pt-24 pb-8">
    <a
      href={`${base}/#proyectos`}
      class="text-[11px] text-muted no-underline tracking-wide transition-colors duration-200 hover:text-text mb-8 inline-block"
    >
      ← volver a proyectos
    </a>

    <article>
      <header class="mb-8 border-b border-border pb-6">
        <h1 class="text-2xl font-bold text-text tracking-tight mb-3">
          {project.data.title}
        </h1>
        <p class="text-xs text-muted-2 leading-[1.9] mb-3">
          {project.data.description}
        </p>
        <div class="flex gap-1.5 flex-wrap">
          {
            project.data.tags.map((tag) => (
              <span class="text-[10px] text-muted tracking-wide border border-border px-2 py-[2px] rounded-sm">
                {tag}
              </span>
            ))
          }
        </div>
      </header>

      <div class="prose">
        <Content />
      </div>
    </article>

    <Footer />
  </div>
</Layout>
