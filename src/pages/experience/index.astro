---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";

const experienceList = (await getCollection("experience")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<Layout
  title="Experiencia Profesional"
  description="Registro de trayectoria y logros en ingeniería electromecánica."
>
  <Nav />

  <div class="w-full max-w-[800px] mx-auto px-8 max-sm:px-5 pt-32 pb-32">
    <div class="mb-20">
      <h1 class="text-[14px] text-muted tracking-widest uppercase mb-4">EXPERIENCE /></h1>
      <p class="text-[15px] text-muted leading-relaxed">
        Registro cronológico de operaciones, diseños y liderazgo técnico.
      </p>
    </div>

    <div class="space-y-16">
      {
        experienceList.map((exp) => (
          <a
            href={`/experience/${exp.id}`}
            class="group block no-underline"
          >
            <div class="flex flex-col gap-1">
              <h3 class="text-[18px] text-text font-medium mb-1 group-hover:text-green transition-colors">
                {exp.data.title}
              </h3>
              <p class="text-[14px] text-muted mb-2">
                {exp.data.company} — {exp.data.period}
              </p>
              <p class="text-[14px] text-muted leading-relaxed mb-4">
                {exp.data.description}
              </p>
              
              <div class="flex flex-wrap gap-3">
                {exp.data.tags?.map(tag => (
                  <span class="text-[13px] text-muted/70">
                    [{tag}]
                  </span>
                ))}
              </div>
            </div>
          </a>
        ))
      }
    </div>

    <div class="pt-24">
      <Footer />
    </div>
  </div>
</Layout>
