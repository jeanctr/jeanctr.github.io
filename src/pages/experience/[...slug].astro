---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const experiences = await getCollection("experience");
  return experiences.map((exp) => ({
    params: { slug: exp.id },
    props: { exp },
  }));
}

const { exp } = Astro.props;
const { Content } = await render(exp);
---

<Layout title={exp.data.title} description={exp.data.description}>
  <Nav />

  <div class="w-full max-w-[800px] mx-auto px-8 max-sm:px-5 pt-32 pb-32">
    <a
      href="/experience"
      class="text-[14px] text-muted hover:text-text mb-16 inline-flex transition-colors no-underline"
    >
      cd ..
    </a>

    <article>
      <header class="mb-14">
         <h1 class="text-[28px] font-medium text-text mb-4 leading-tight">
           {exp.data.title}
         </h1>
         <div class="flex items-center gap-2 mb-8 text-[14px] text-muted">
            <span>{exp.data.company}</span>
            <span>/</span>
            <span>{exp.data.period}</span>
         </div>
         
        <div class="flex gap-4 flex-wrap">
          {
            exp.data.tags?.map((tag) => (
              <span class="text-[13px] text-muted/80">
                [{tag}]
              </span>
            ))
          }
        </div>
      </header>

      {exp.data.image && (
        <div class="mb-14 opacity-80 hover:opacity-100 transition-opacity">
            <img src={exp.data.image} alt={exp.data.title} class="w-full h-auto max-h-[400px] object-cover" />
        </div>
      )}

      <div class="prose max-w-none">
        <Content />
      </div>
    </article>

    <div class="pt-24">
      <Footer />
    </div>
  </div>
</Layout>
