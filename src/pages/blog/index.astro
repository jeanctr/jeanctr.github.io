---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

---

<Layout
  title="Blog"
  description="Posts sobre ingeniería, programación y tecnología"
>
  <Nav />

  <div class="page">
    <div class="section fade">
      <p class="s-label">blog</p>

      {
        posts.length === 0 ? (
          <p class="about-text">No hay posts publicados todavía.</p>
        ) : (
          posts.map((post) => (
            <a href={`/blog/${post.id}`} class="blog-teaser">
              <p>{post.data.title}</p>
              <span>
                {post.data.pubDate.toLocaleDateString('es-ES', { month: 'short', year: 'numeric' })} →
              </span>
            </a>
          ))
        )
      }
    </div>
    <Footer />
  </div>
</Layout>
