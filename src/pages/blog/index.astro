---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog" description="Posts sobre ingeniería, programación y tecnología">
  <Nav />

  <div class="max-w-[660px] mx-auto px-8 max-sm:px-5 pt-24 pb-8">
    <h1 class="text-2xl font-bold text-text tracking-tight mb-8">Blog</h1>

    {
      posts.length === 0 ? (
        <p class="text-xs text-muted-2">No hay posts publicados todavía.</p>
      ) : (
        posts.map((post, i) => (
          <a
            href={`/blog/${post.id}`}
            class:list={[
              'group flex items-baseline justify-between py-[0.8rem] px-2 border-b border-border no-underline transition-all duration-[120ms] hover:bg-green-dim hover:pl-4',
              i === 0 && 'border-t',
            ]}
          >
            <span class="text-[13px] text-text group-hover:text-green transition-colors duration-150">
              {post.data.title}
            </span>
            <span class="text-[10px] text-muted tracking-wide ml-4 shrink-0">
              {post.data.pubDate.toLocaleDateString('es-BO', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </span>
          </a>
        ))
      )
    }

    <Footer />
  </div>
</Layout>
