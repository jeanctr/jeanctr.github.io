---
const contacts = [
  {
    key: 'email',
    value: 'jeancarlos.ingenieria@gmail.com',
    href: 'mailto:jeancarlos.ingenieria@gmail.com',
  },
  {
    key: 'linkedin',
    value: '/in/jeancarlostr',
    href: 'https://www.linkedin.com/in/jeancarlostr',
  },
  {
    key: 'github',
    value: 'github.com/jeanctr',
    href: 'https://github.com/jeanctr',
  },
];
---

<section id="contacto">
  <h2 class="text-[12px] font-bold text-text uppercase tracking-widest mb-12">
    Contacto
  </h2>

  <div class="space-y-4">
    {
      contacts.map(({ key, value, href }) => (
        <a
          href={href}
          target={key !== 'email' ? '_blank' : undefined}
          class="sm:grid sm:grid-cols-[140px_1fr] sm:gap-6 flex flex-col gap-1 group no-underline"
        >
          <span class="text-[13px] text-muted font-mono mt-1">
            {key}
          </span>
          <div class="flex items-center gap-3">
            <span class="text-[16px] text-text font-medium group-hover:text-green transition-colors tracking-tight">
              {value}
            </span>
            <span class="text-[14px] text-muted opacity-0 group-hover:opacity-100 transition-opacity translate-x-[-10px] group-hover:translate-x-0 duration-200">
              →
            </span>
          </div>
        </a>
      ))
    }
  </div>
</section>
