---
interface Props {
  num: string;
  title: string;
  description: string;
  tags: string[];
  isFirst?: boolean;
}

const { num, title, description, tags, isFirst = false } = Astro.props;
---

<div
  class:list={[
    'grid grid-cols-[auto_1fr] gap-x-6 gap-y-5 items-start py-[1.4rem] px-2 border-b border-border transition-all duration-[120ms] hover:bg-green-dim hover:pl-4',
    isFirst && 'border-t',
  ]}
>
  <span
    class="text-[10px] text-green font-bold tracking-wide pt-[3px] min-w-[24px]"
  >
    {num}
  </span>
  <div>
    <p class="text-[13px] text-text font-medium mb-1">{title}</p>
    <p class="text-[11px] text-muted-2 leading-[1.85] mb-2">{description}</p>
    <div class="flex gap-1.5 flex-wrap">
      {
        tags.map((tag) => (
          <span class="text-[10px] text-muted tracking-wide border border-border px-2 py-[2px] rounded-sm">
            {tag}
          </span>
        ))
      }
    </div>
  </div>
</div>
