---
const infoItems = [
  { key: 'experiencia', value: '+3 años', green: true },
  { key: 'especialidad', value: 'Eléctrica MT/BT', green: false },
  { key: 'diseño', value: 'AutoCAD · Revit', green: false },
  { key: 'ubicación', value: 'Bolivia', green: false },
];
---

<section id="sobre-mi">
  <h2 class="text-[12px] font-bold text-text uppercase tracking-widest mb-12">
    Sobre Mí
  </h2>

  <div class="text-[16px] text-muted-2 leading-relaxed mb-16">
    <p>
      Soy ingeniero electromecánico apasionado por el <span class="text-text font-medium"
        >diseño eléctrico</span
      > y la integración de sistemas. Mi trabajo combina conocimiento técnico sólido
      con herramientas de diseño y programación.
    </p>
    <p class="mt-6">
      Me especializo en redes de <span class="text-text font-medium"
        >media y baja tensión</span
      >, con enfoque en precisión de planos y correcta aplicación de normativas
      técnicas.
    </p>
    <p class="mt-6">
      Manejo también <span class="text-text font-medium">Python, JavaScript y Git</span>,
      lo que me permite abordar proyectos con un enfoque moderno y eficiente.
    </p>
  </div>

  <div class="space-y-4">
    {
      infoItems.map(({ key, value, green }) => (
        <div class="sm:grid sm:grid-cols-[140px_1fr] sm:gap-6 flex flex-col gap-1 items-baseline">
          <p class="text-[13px] font-mono text-muted uppercase">{key}</p>
          <p class={`text-[16px] font-medium tracking-tight ${green ? 'text-green' : 'text-text'}`}>
            {value}
          </p>
        </div>
      ))
    }
  </div>
</section>
