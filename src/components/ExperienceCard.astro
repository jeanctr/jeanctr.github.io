---
import type { CollectionEntry } from "astro:content";

interface Props {
  exp: CollectionEntry<"experience">;
}

const { exp } = Astro.props;
---

<div class="relative pl-10 max-sm:pl-0 group reveal">
  <!-- Punto de la línea de tiempo -->
  <div
    class="absolute left-0 top-2 w-3.5 h-3.5 rounded-full border-2 border-green bg-bg z-10 ml-0 transition-transform duration-300 group-hover:scale-125 max-sm:hidden"
  >
  </div>

  <div class="flex flex-col gap-1 items-start">
    <span
      class="text-[11px] font-mono text-muted uppercase tracking-[0.05em] mb-1"
      >{exp.data.period}</span
    >
    <h3
      class="text-[17px] font-bold text-text tracking-tight group-hover:text-green transition-colors duration-300"
    >
      {exp.data.title}
    </h3>
    <span class="text-[13px] text-muted-2 font-medium mb-3 italic"
      >{exp.data.company}</span
    >
    <p class="text-[14px] text-muted-2 leading-[1.8] max-w-[600px] mb-4">
      {exp.data.description}
    </p>
    <div class="flex gap-2 flex-wrap">
      {
        exp.data.tags?.map((tag: string) => (
          <span class="text-[10px] font-mono text-muted border border-border px-2 py-0.5 rounded-sm bg-surface/30">
            {tag}
          </span>
        ))
      }
    </div>
  </div>
</div>
