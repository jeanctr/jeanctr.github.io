<button
  id="theme-toggle"
  class="relative flex h-8 w-8 items-center justify-center rounded-md border border-border bg-surface transition-all hover:bg-green-dim group"
  aria-label="Alternar tema"
>
  <!-- Sun Icon (Visible in light mode) -->
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="h-[14px] w-[14px] transition-all absolute opacity-0 scale-50 rotate-90 dark:opacity-100 dark:scale-100 dark:rotate-0 text-green"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2"></path>
    <path d="M12 20v2"></path>
    <path d="m4.93 4.93 1.41 1.41"></path>
    <path d="m17.66 17.66 1.41 1.41"></path>
    <path d="M21 12h2"></path>
    <path d="M9 12H2"></path>
    <path d="m19.07 4.93-1.41 1.41"></path>
    <path d="m6.34 17.66-1.41 1.41"></path>
  </svg>

  <!-- Moon Icon (Visible in dark mode) -->
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="h-[14px] w-[14px] transition-all absolute opacity-100 scale-100 rotate-0 dark:opacity-0 dark:scale-50 dark:rotate-90 text-green"
  >
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
  </svg>
</button>

<style>
  /* Local overrides for Tailwind dark variant in Astro components if needed */
  :global(.light) #theme-toggle svg:nth-child(2) {
    opacity: 1 !important;
    transform: scale(1) rotate(0);
  }
  
  :global(.light) #theme-toggle svg:nth-child(1) {
    opacity: 0 !important;
    transform: scale(0.5) rotate(90deg);
  }

  /* When NOT in light mode (default dark) */
  #theme-toggle svg:nth-child(1) {
    opacity: 1;
    transform: scale(1) rotate(0);
  }
  #theme-toggle svg:nth-child(2) {
    opacity: 0;
    transform: scale(0.5) rotate(90deg);
  }
</style>

<script>
  const handleToggleClick = () => {
    const element = document.documentElement;
    element.classList.toggle("light");

    const isLight = element.classList.contains("light");
    localStorage.setItem("theme", isLight ? "light" : "dark");
  };

  document.getElementById("theme-toggle")?.addEventListener("click", handleToggleClick);
</script>
