---
const experiences = [
  {
    date: "2023 — Presente",
    title: "Ingeniero Electromecánico Senior",
    company: "Proyectos Industriales SCZ",
    description: "Liderazgo en diseño conceptual y ejecución de subestaciones de 69/13.8 kV. Optimización de redes de distribución MT/BT y coordinación de protecciones eléctricas.",
    tags: ["Media Tensión", "ETAP", "Gestión de Proyectos"]
  },
  {
    date: "2021 — 2023",
    title: "Diseñador de Instalaciones Eléctricas",
    company: "Estudio de Ingeniería Electromecánica",
    description: "Elaboración de planos ejecutivos para edificios de +12 pisos. Cálculo de carga, dimensionamiento de tableros y sistemas de puesta a tierra bajo normativa técnica.",
    tags: ["AutoCAD", "Revit", "Baja Tensión"]
  }
];
---

<section id="experiencia" class="py-[5rem] border-b border-border relative overflow-hidden">
  <p
    class="text-[11px] text-green font-mono tracking-[0.2em] uppercase mb-12 flex items-center gap-4 after:content-[''] after:flex-1 after:h-px after:bg-border/60"
  >
    experiencia profesional
  </p>

  <div class="space-y-12 relative">
    <!-- Línea vertical técnica -->
    <div class="absolute left-0 top-2 bottom-2 w-px bg-border/40 ml-[7px] max-sm:hidden"></div>

    {
      experiences.map((exp) => (
        <div class="relative pl-10 max-sm:pl-0 group reveal">
          <!-- Punto de la línea de tiempo -->
          <div class="absolute left-0 top-2 w-3.5 h-3.5 rounded-full border-2 border-green bg-bg z-10 ml-0 transition-transform duration-300 group-hover:scale-125 max-sm:hidden"></div>
          
          <div class="flex flex-col gap-1 items-start">
            <span class="text-[11px] font-mono text-muted uppercase tracking-[0.05em] mb-1">{exp.date}</span>
            <h3 class="text-[17px] font-bold text-text tracking-tight group-hover:text-green transition-colors duration-300">
              {exp.title}
            </h3>
            <span class="text-[13px] text-muted-2 font-medium mb-3 italic">{exp.company}</span>
            <p class="text-[14px] text-muted-2 leading-[1.8] max-w-[600px] mb-4">
              {exp.description}
            </p>
            <div class="flex gap-2 flex-wrap">
              {exp.tags.map(tag => (
                <span class="text-[10px] font-mono text-muted border border-border px-2 py-0.5 rounded-sm bg-surface/30">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>
